{
  "name": "mytory-video-tool",
  "version": "1.7.1",
  "description": "Unified high-performance native desktop video utilities.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run dist:release",
    "dist:test": "dotenv -- electron-builder --dir -c.mac.identity=-",
    "dist:release": "dotenv -- electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "video",
    "ffmpeg",
    "pitch-preserved",
    "trim",
    "remux",
    "capture"
  ],
  "author": {
    "name": "mytory",
    "email": "mail@mytory.net",
    "url": "https://mytory.net"
  },
  "license": "GPL-3.0-only",
  "type": "commonjs",
  "supportedArchitectures": {
    "os": [
      "darwin",
      "linux",
      "win32"
    ],
    "cpu": [
      "x64",
      "arm64"
    ]
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "exiftool-vendored": "^36.0.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "net.mytory.videotool",
    "productName": "Mytory Video Tools",
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "afterPack": "build/afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*",
      "**/node_modules/@img/**/*"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "artifactName": "${name}-v${version}-${arch}.${ext}",
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${name}-Setup-v${version}.${ext}"
    },
    "linux": {
      "icon": "build/icon-transparent-bg.png",
      "target": "AppImage",
      "artifactName": "${name}-v${version}.${ext}"
    }
  }
}

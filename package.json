{
  "name": "mytory-video-tool",
  "version": "1.0.0",
  "description": "Unified high-performance native desktop video utilities.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run dist:release",
    "dist:test": "dotenv -- electron-builder --dir -c.mac.identity=-",
    "dist:release": "dotenv -- electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "video",
    "ffmpeg",
    "pitch-preserved",
    "trim",
    "remux",
    "capture"
  ],
  "author": "mytory",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  },
  "build": {
    "appId": "net.mytory.videotool",
    "productName": "Mytory Video Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*"
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg",
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
